<div class="l-models">
    {# {{ openSection(1, 2)|raw }}
    {% include 'components/atoms/site-heading/site-heading.twig' with {
        heading: 'Wszystkie modele',
        description: 'Zapoznaj się z naszą ofertą'
    } %}
    {{ closeSection()|raw }} #}
    <div class="l-models__container container">
        {% include 'layouts/models/mobile-accordion.twig' with {
            categories: carCategories
        } only %}
        {% include 'layouts/models/desktop-tabs.twig' with {
            categories: carCategories
        } only %}
    </div>
    {% if hasPopup %}
        <div class="l-models__stock-info">
            <div class="l-models__stock-info-container container">
                <div class="l-models__stock-info-column js-sticky" data-sticky-media-query="(min-width: 1200px)" data-sticky-mode="bottom" data-sticky-offset-bottom="135">
                    <div class="l-models__stock-info-box box js-sticky__element">
                        <h2 class="box__heading">{{ popup.heading }}</h2>
                        <div class="box__description">
                            <p>{{ popup.description }}</p>
                        </div>
                        {% if popup.link %}
                            <div class="box__bottom">
                                <a href="{{ popup.link.url }}" class="box__link"{% if nofollow %} rel="noopener noreferrer nofollow"{% endif %}{% if target == '_blank' %} target="_blank" {% endif %}>{{ popup.link.text }}</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <style>
            .l-models__stock-info-column.is-sticky-under .l-models__stock-info-box {
                bottom:-20px;
            }
        </style>
    {% endif %}
</div>