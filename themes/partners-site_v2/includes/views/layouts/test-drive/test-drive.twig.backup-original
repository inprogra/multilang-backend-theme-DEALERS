<div class="l-test-drive js-test-drive">
    <div class="l-test-drive__container container">
        <div class="l-test-drive__wrapper">
            <div class="l-test-drive__main main">
                <div class="main__inner js-sticky__element">
                    <div class="main__header">
                        <h1 class="main__heading">Jazda testowa</h1>
                        <h2 class="main__subheading">Zapoznaj się z gamą modeli i umów jazdę testową.</h2>
                    </div>
                    <div class="main__content testDriveMaincontent">
                 

                        <div class="main__groups js-test-drive__models">
                        
                          <div class="testdriveMainContainer">
                          <div class="choseModels">
                            <h2>Wybierz model </h2>
                          </div>

                           {% set groupedCarTypes = {} %}
                            {% for category in testDrive %}
                                {% for carType in category.carTypes %}
                                    {% set name = carType.name %}
                                    {% if groupedCarTypes[name] is not defined %}
                                        {% set groupedCarTypes = groupedCarTypes|merge({ (name): [] }) %}
                                    {% endif %}
                                    {% set groupedCarTypes = groupedCarTypes|merge({
                                        (name): groupedCarTypes[name]|merge([carType])
                                    }) %}
                                {% endfor %}
                            {% endfor %}
                                {% for typeName, carTypeList in groupedCarTypes %}
                                    <div class="testDrivecategory">
                                        <h3>{{ typeName }}</h3>
                                    </div>
                                    <div class="testDriveCategoryContainer">
                                        {% for carType in carTypeList %}
                                            {% for car in carType.cars %}
                                                <div class="testDriveBox">
                                                    <a href="/jazda-testowa-model-{{ car.slug }}"> 

                                                        <div class="testDriveImageContainer">
                                                        {% if car.imageDesktop %}
                                                        {% include 'components/atoms/image/image-query.twig' with {
                                                        additionalClass: '',
                                                        image: car.imageDesktop
                                                    } %}
                                                        {% endif %}
                                                        </div>
                                                        <div class="testDriveModelName">
                                                            <p>{{ car.short_name ?: car.name }}</p>
                                                        </div>
                                                    </a>
                                                </div>
                                            {% endfor %}
                                        {% endfor %}
                                    </div>
                                {% endfor %}
                            </div>
                          </div>            
                        </div>
                    </div>
                    
                </div>
            </div>
           
        </div>
    </div>
</div>
<style>
.testDriveMaincontent{
    width: 100%;
    height: auto;
    overflow: none; 
    display: block !important;
}
.l-test-drive__container{
    max-width: 1604px !important;
    width: 95% !important;
}
    @media screen and (max-width:576px) {
        .l-test-drive__container{
            width: 100% !important;
        }
    }

.l-test-drive .main__groups{
    width: 100% !important;
    max-width: 100% !important;
}
@media screen and (min-width:998px) {
/* .l-test-drive .main__groups {
    max-width:100%;
    display:flex;   
    flex-wrap:wrap;
    flex-direction:row;
} */
.l-test-drive .main__groups > div {
    
    flex: 1 0 21%; /* explanation below */
    margin: 5px;
    text-align:center;
}
}
.l-test-drive .main__groups > div a {
    display:block;
    width:100%;
}
.full-width {
    width:100%;
}
.main__model  a {
    color:rgb(22, 42, 70);
}
.model__label p {
    text-align:center;
}
.d-none {
    display:none;
}
.model__label {
    width:100%;
}
.model__label span,
.model__label span::before {
    display:none!important;
}
.main__inner.js-sticky__element {
    left:0!important;
    right:0;
}
.l-test-drive__main.is-sticky .main__inner,
.l-test-drive__main.is-sticky-under .main__inner {
    position:relative;
}
.l-test-drive .main__model {
    width:100%;
}
</style>
<script type="text/javascript">
$(document).ready(function() {
    $('a.link_model_href').click(function() {
        document.location.href = $(this).attr('href');
    })
});
</script>
