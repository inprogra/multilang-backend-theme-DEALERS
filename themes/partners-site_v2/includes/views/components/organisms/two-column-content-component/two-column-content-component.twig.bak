{% set classes = [
    additionalClass|e('html_attr'),
    'o-two-column-content-component'
] %}

{% if reverse %}
    {% set classes = classes|merge(['o-two-column-content-component--reverse']) %}
{% endif %}

{% if not equalColumns %}
    {% set classes = classes|merge(['o-two-column-content-component--two-third']) %}
{% endif %}

{% if video %}
    {% set classes = classes|merge(['o-two-column-content-component--has-video']) %}
{% endif %}

<div class="{{ classes|join(' ') }} container">
    <div class="o-two-column-content-component__inner">
        <div class="o-two-column-content-component__column o-two-column-content-component__column--img">
            {% if video %}
                {% include 'components/atoms/video/video.twig' with {
                    additionalClass: 'o-two-column-content-component__video',
                    image: image,
                    video: video
                } only %}
            {% elseif image %}
                {% include 'components/atoms/image/image.twig' with image|merge({
                    additionalClass: 'o-two-column-content-component__img'
                }) %}
            {% endif %}
        </div>
        <div class="o-two-column-content-component__column o-two-column-content-component__column--content">
            <div class="o-two-column-content-component__content content">
                {% if subheading %}
                    <p class="content__subheading">{{ subheading }}</p>
                {% endif %}
                {% if heading %}
                    <h2 class="h3 content__heading">{{ heading }}</h2>
                {% endif %}
                {% if content %}
                    {% for contentItem in content %}
                        {% if contentItem.acf_fc_layout == 'description' %}
                            <div class="content__description">
                                <p>a
                                    {{ contentItem.description }}
                                </p>
                            </div>
                        {% elseif contentItem.acf_fc_layout == 'contact-info' %}
                            <div class="content__contact-info-wrapper">
                                {% include 'components/atoms/contact-info/contact-info.twig' with contentItem.contactPerson|merge ({
                                    additionalClass: 'content__contact-info',
                                }) only %}
                            </div>
                        {% elseif contentItem.acf_fc_layout == 'link' %}
                            {% if contentItem.buttonAction == 'form' %}
                                {% include 'components/atoms/button/button.twig' with {
                                    additionalClass: 'content__link js-open-side-form',
                                    secondary: true,
                                    text: contentItem.buttonText
                                } only %}
                            {% elseif contentItem.link %}
                               
                                {% include 'components/atoms/button/button-link.twig' with contentItem.link|merge({
                                    additionalClass: 'content__link',
                                    secondary: true
                                }) only %}
                            {% endif %}
                        {% elseif contentItem.acf_fc_layout == 'table' %}
                            <dl class="content__table table">
                                {% for item in contentItem.table %}
                                    <dt class="table__label">{{ item.label }}</dt>
                                    <dd class="table__value">{{ item.value }}</dd>
                                {% endfor %}
                            </dl>
                        {% elseif contentItem.acf_fc_layout == 'list' %}
                            <ul class="content__list list">
                                {% for item in contentItem.list %}
                                    <li class="list__item">{{ item.text }}</li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    {% endfor %}
                {% endif %}
                {% if buttons %}
                    <div class="content__buttons">
                        {% for button in buttons %}
                            <div class="content__buttons-item">
                                {% set additionalClass = ['content__buttons-link'] %}

                                {% if button.additionalClass %}
                                    {% set additionalClass = additionalClass|merge([button.additionalClass]) %}
                                {% endif %}

                                {% include 'components/atoms/button/button-link.twig' with button|merge({
                                    additionalClass: additionalClass|join(' '),
                                    secondary: true
                                }) only %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>