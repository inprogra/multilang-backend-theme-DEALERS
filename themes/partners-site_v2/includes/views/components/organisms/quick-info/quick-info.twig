<div class="grey_section">
    <div class="container">
        {% set x = 1 %}
        <div class="quick-notes-container">
            {% for item in items %}
            <div class="quick-info quick-info-{{x}}" >
                    <div class="first_title">{{item.field_uptitle}}</div>
                    <div class="second_title">{{item.field_midtitle}}</div>
                    <div class="third_title">{{item.field_lowtitle}}</div>
            </div>

            {% set x = x + 1 %}
            {% endfor %}
        </div>
    </div>
</div>
<style>
.grey_section {
    
    width:100%;
  
}
.grey_section .container {
    
    
}
.quick-notes-container {
    display:flex;
    background: #FAFAFA;
    justify-content: space-between;
    width:100%;
   
    margin:0 auto;
    padding-bottom:28px;
    padding-top:80px
}
.quick-notes-container > div {
    width:100%;
    height: 110px;
}
.quick-notes-container > div .first_title {
    font-weight:400;
    color:#6d6d6d;
    font-size:14px;
    line-height:20px;
    text-align:center;
}
.quick-notes-container > div .second_title {
    font-weight:600;
    color:#141414;
    font-size:32px;
    line-height:36px;
    text-align:center;
    margin:0 8px;
}
.quick-notes-container > div .third_title {
    font-weight:400;
    color:#6d6d6d;
    font-size:14px;
    line-height:20px;
    text-align:center;
}
@media screen and (max-width:997px) {
    .quick-notes-container {
        display:block;
    }
    .quick-notes-container {
        padding-top:40px;
    }
}
</style>