{% if showOffer %}
<div class="specialOfferMainContainer">
    <div class="specialOfferMainRow">
        <div class="specialOfferDescriptionContainer">
            <div class="specialOfferDescription">
                <p>{{ title }}</p>
            </div> 
            <div class="specialOfferLinks">
                <a href="{{ link.url }}" target="{{ link.target }}">
                    {{link.title}}
                </a>
            </div>
        </div>
        <div class="specialOfferCloseContainer">
            <div class="closeOfferBtn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M2.64645 2.64645C2.84171 2.45118 3.15829 2.45118 3.35355 2.64645L8 7.29289L12.6464 2.64645C12.8417 2.45118 13.1583 2.45118 13.3536 2.64645C13.5488 2.84171 13.5488 3.15829 13.3536 3.35355L8.70711 8L13.3536 12.6464C13.5488 12.8417 13.5488 13.1583 13.3536 13.3536C13.1583 13.5488 12.8417 13.5488 12.6464 13.3536L8 8.70711L3.35355 13.3536C3.15829 13.5488 2.84171 13.5488 2.64645 13.3536C2.45118 13.1583 2.45118 12.8417 2.64645 12.6464L7.29289 8L2.64645 3.35355C2.45118 3.15829 2.45118 2.84171 2.64645 2.64645Z" fill="white"/>
                </svg>
            </div>
        </div>
    </div>
</div>
{% endif %}



<script type="text/javascript">
    $(document).ready(function(){


        var navigationHeight = $(".o-header__bar").outerHeight(true);
        $(".specialOfferMainContainer").css('top',navigationHeight +'px');

        setTimeout(function() {
            $(".specialOfferMainContainer").animate({
                opacity: 1
            },600);
      }, 2000);
        
        $(".specialOfferCloseContainer").click(function(){

            $(".specialOfferMainContainer").animate({
                opacity: 0
            },600, function(){
                $(this).css('display','none');
            })
        });



    })

</script>