<div class="container">
<div class="short-notes-all short-notes-boxes">
{% set x = 1 %}
{% for item in items %}
   <div class="short-notes short-box-{{x}}" >
        <h2>{{item.field_notetitle}}</h2>
        <p>{{item.field_notesdesc}}</p>
   </div>

{% set x = x + 1 %}
{% endfor %}
</div>
</div>
<style>
.short-notes-all.short-notes-boxes {
    display:flex;
    margin:80px 0 ;
     
}
.short-notes {
    padding-left:55px;
    max-width:288px;
    width:100%;
     height:131px;
     margin: 0 20px;
}
.short-notes h2 {
    font-weight:500;
    color:#141414;
    font-size:16px;
    line-height:19px;
}
.short-notes p {
    font-weight:400;
    font-size:12px;
    line-height:18px;
    color:#6d6d6d;
    
   
}
.short-box-1 {
    background: url('/img/1a.png') left top no-repeat;
}
.short-box-2 {
    background: url('/img/2a.png') left top no-repeat;
}
.short-box-3 {
    background: url('/img/3a.png') left top no-repeat;
}
.short-box-4 {
    background: url('/img/4a.png') left top no-repeat;
}
@media screen and (max-width:997px) {
    .short-notes-all.short-notes-boxes {
    display:block;
    margin:80px 0 ;    

}
.short-notes {
    margin:0 auto;
    padding-left: 38px;
}
.short-notes h2 {
    padding-top:12px;
}
.short-notes-all > div {
    margin-bottom:30px!important;
}
</style>